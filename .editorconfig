# EditorConfig — https://editorconfig.org
# Top-most config in the repository.
root = true

# Defaults for every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# C / C++ / Arduino firmware
[*.{ino,h,hpp,c,cpp}]
indent_size = 2
max_line_length = 100

# Documentation — preserve trailing spaces (Markdown hard line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# PowerShell tools — Windows conventions
[*.ps1]
end_of_line = crlf
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# YAML (CI, templates)
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
